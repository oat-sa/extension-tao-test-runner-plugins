msgid ""
msgstr ""

msgid "%s actions were successfully imported"
msgstr "Akcie %s boli úspešne importované"

msgid "%s deliveries were updated"
msgstr "%s doručení bolo aktualizovaných"

msgid "%s deliveries will be updated"
msgstr ""

msgid "All students will begin the next section at the same time. Please relax quietly until the room supervisor starts the next section."
msgstr "Všetci študenti začnú s ďalšou časťou súčasne. Prosím, pokojne sa uvoľnite, kým vedúci triedy nezačne s ďalšou časťou."

msgid "Assessment ended. Please email the downloaded file to complete the process."
msgstr "Hodnotenie ukončené. Pre dokončenie procesu pošlite stiahnutý súbor e-mailom."

msgid "Assessment Item"
msgstr "Hodnotená položka"

msgid "Attempt to navigate to another window or tab."
msgstr "Skúste prejsť do iného okna alebo karty."

msgid "Cannot find any actions for importing."
msgstr "Nepodarilo sa nájsť žiadne akcie na import."

msgid "Delivery execution %s is not active state."
msgstr "Stav doručenia %s nie je aktívny."

msgid "Download & End Assessment"
msgstr "Stiahnuť a ukončiť hodnotenie"

msgid "Fail to import test actions with message: "
msgstr "Nepodarilo sa importovať testovacie akcie so správou: "

msgid "Import a test sent to you by an offline test taker."
msgstr "Importujte test, ktorý vám poslal offline účastník testu."

msgid "Invalid MimeType of file"
msgstr "Neplatný typ súboru MimeType"

msgid "JSON with test actions"
msgstr "JSON s testovacími akciami"

msgid "Migrate to use delivery features to control security plugins"
msgstr "Migrácia na používanie funkcií doručovania na ovládanie bezpečnostných doplnkov"

msgid "or"
msgstr "alebo"

msgid "Please continue waiting while we try to restore the connection. Alternatively, you may end this test by downloading it as a file which you will have to submit manually."
msgstr "Prosím, čakajte, kým sa pokúsime obnoviť pripojenie. Prípadne môžete tento test ukončiť stiahnutím súboru, ktorý budete musieť odoslať manuálne."

msgid "Please wait while we try to restore the connection."
msgstr "Počkajte, prosím, kým sa pokúsime obnoviť pripojenie."

msgid "Several resources URIs do not belong to the instance where the test was passed"
msgstr "Niekoľko URI zdrojov nepatrí k inštancii, v ktorej bol test úspešný."

msgid "Test actions imported successfully. Imported execution %s"
msgstr "Testovacie akcie boli úspešne importované. Importované vykonanie %s"

msgid "Test actions importing"
msgstr "Import testovacích akcií"

msgid "Test could not be launched. Test must always be launched in a full screen mode."
msgstr "Test sa nepodarilo spustiť. Test sa musí vždy spustiť v režime celej obrazovky."

msgid "The assessment has been paused due to an attempt to navigate to another window or tab. Please contact your proctor or administrator to resume your assessment."
msgstr "Hodnotenie bolo pozastavené z dôvodu pokusu o prechod do iného okna alebo karty. Ak chcete pokračovať v hodnotení, kontaktujte svojho dozorcu alebo administrátora."

msgid "The assessment has been paused due to an attempt to print screen. Please contact your proctor or administrator to resume your assessment."
msgstr "Hodnotenie bolo pozastavené z dôvodu pokusu o vytlačenie snímky obrazovky. Ak chcete pokračovať v hodnotení, kontaktujte svojho dozorcu alebo administrátora."

msgid "The connection seems to be back, please proceed"
msgstr "Zdá sa, že pripojenie je obnovené, pokračujte prosím."

msgid "The download will be available in <strong>%d</strong> seconds"
msgstr "Stiahnutie bude k dispozícii o <strong>%d</strong> sekúnd"

msgid "This test needs to be taken in full screen mode (%s)."
msgstr "Tento test je potrebné absolvovať v režime celej obrazovky (%s)."

msgid "To hide watermark, type keyword"
msgstr "Ak chcete skryť vodoznak, zadajte kľúčové slovo"

msgid "To show watermark, type keyword"
msgstr "Ak chcete zobraziť vodoznak, zadajte kľúčové slovo"

msgid "Upload"
msgstr "Nahrať"

msgid "Upload offline test"
msgstr "Nahrať offline test"

msgid "You are encountering a connectivity loss. The test has been suspended."
msgstr "Došlo k výpadku pripojenia. Test bol pozastavený."

msgid "You are encountering a prolonged connectivity loss."
msgstr "Dochádza k dlhodobému výpadku pripojenia."

msgid "You are encountering a prolonged connectivity loss. "
msgstr "Dochádza k dlhodobému výpadku pripojenia. "

